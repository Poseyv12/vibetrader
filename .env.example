# Copy to .env.local and fill in. Keys can also be set later on the /settings page.

# Alpaca PAPER trading keys — https://app.alpaca.markets (paper dashboard)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...

# LM Studio local server (optional — these are the defaults)
# LMSTUDIO_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=qwen/qwen3-4b-2507
# LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
